{
    "name": "hup234design/filament-cms",
    "require": {
        "php": "^8.1",
        "awcodes/filament-curator": "^3.4",
        "awcodes/filament-table-repeater": "^3.0",
        "awcodes/filament-tiptap-editor": "^3.0",
        "diglactic/laravel-breadcrumbs": "^8.1",
        "filament/filament": "^3.2",
        "ralphjsmit/laravel-filament-components": "^2.0",
        "ralphjsmit/laravel-filament-seo": "^1.2",
        "solution-forest/filament-tree": "^2.0",
        "spatie/eloquent-sortable": "^4.1",
        "spatie/image": "^2.2",
        "spatie/laravel-cookie-consent": "^3.2",
        "spatie/laravel-google-fonts": "^1.2",
        "spatie/laravel-honeypot": "^4.4",
        "spatie/laravel-package-tools": "^1.13.5",
        "spatie/laravel-ray": "^1.33",
        "spatie/valuestore": "^1.3"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hup234design\\FilamentCms\\": "src/",
            "Hup234design\\FilamentCms\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hup234design\\FilamentCms\\FilamentCmsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
